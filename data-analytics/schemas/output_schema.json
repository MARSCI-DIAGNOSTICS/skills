{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Data Analytics Skill Output Schema",
  "description": "Deterministic structured output contract for Level 2 Statistical Engine.",
  "type": "object",
  "required": ["analysis_type", "results", "interpretation"],
  "properties": {

    "analysis_type": {
      "type": "string",
      "enum": [
        "eda",
        "linear_regression",
        "logistic_regression",
        "hypothesis_test",
        "correlation"
      ]
    },

    "results": { "type": "object" },

    "model_diagnostics": { "type": "object" },

    "assumption_tests": { "type": "object" },

    "confidence_level": {
      "type": "number",
      "minimum": 0.8,
      "maximum": 0.999
    },

    "interpretation": {
      "type": "object",
      "required": ["summary"],
      "properties": {
        "summary": { "type": "string" },
        "key_findings": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }

  },

  "additionalProperties": false,

  "allOf": [

    {
      "if": { "properties": { "analysis_type": { "const": "eda" } } },
      "then": {
        "properties": {
          "results": {
            "type": "object",
            "required": ["summary_statistics"],
            "properties": {
              "summary_statistics": { "type": "object" },
              "correlation_matrix": { "type": "object" },
              "missing_analysis": { "type": "object" },
              "outlier_analysis": { "type": "object" }
            },
            "additionalProperties": false
          }
        },
        "not": {
          "anyOf": [
            { "required": ["model_diagnostics"] },
            { "required": ["assumption_tests"] },
            { "required": ["confidence_level"] }
          ]
        }
      }
    },

    {
      "if": { "properties": { "analysis_type": { "const": "linear_regression" } } },
      "then": {
        "required": ["model_diagnostics", "assumption_tests", "confidence_level"],
        "properties": {
          "results": {
            "type": "object",
            "required": ["coefficients", "model_metrics"],
            "properties": {

              "coefficients": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "required": ["estimate", "p_value", "confidence_interval"],
                  "properties": {
                    "estimate": { "type": "number" },
                    "p_value": { "type": "number" },
                    "confidence_interval": {
                      "type": "array",
                      "minItems": 2,
                      "maxItems": 2,
                      "items": { "type": "number" }
                    }
                  },
                  "additionalProperties": false
                }
              },

              "model_metrics": {
                "type": "object",
                "required": [
                  "r_squared",
                  "adjusted_r_squared",
                  "aic",
                  "bic",
                  "rmse",
                  "residual_variance"
                ],
                "properties": {
                  "r_squared": { "type": "number" },
                  "adjusted_r_squared": { "type": "number" },
                  "aic": { "type": "number" },
                  "bic": { "type": "number" },
                  "rmse": { "type": "number" },
                  "residual_variance": { "type": "number" }
                },
                "additionalProperties": false
              }

            },
            "additionalProperties": false
          }
        }
      }
    },

    {
      "if": { "properties": { "analysis_type": { "const": "logistic_regression" } } },
      "then": {
        "required": ["model_diagnostics", "assumption_tests", "confidence_level"],
        "properties": {
          "results": {
            "type": "object",
            "required": ["coefficients", "model_metrics"],
            "properties": {

              "coefficients": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "required": ["estimate", "odds_ratio", "p_value"],
                  "properties": {
                    "estimate": { "type": "number" },
                    "odds_ratio": { "type": "number" },
                    "p_value": { "type": "number" }
                  },
                  "additionalProperties": false
                }
              },

              "model_metrics": {
                "type": "object",
                "required": ["aic", "bic", "pseudo_r_squared"],
                "properties": {
                  "aic": { "type": "number" },
                  "bic": { "type": "number" },
                  "pseudo_r_squared": { "type": "number" }
                },
                "additionalProperties": false
              }

            },
            "additionalProperties": false
          }
        }
      }
    },

    {
      "if": { "properties": { "analysis_type": { "const": "hypothesis_test" } } },
      "then": {
        "required": ["confidence_level"],
        "properties": {
          "results": {
            "type": "object",
            "required": ["test_statistic", "p_value"],
            "properties": {
              "test_statistic": { "type": "number" },
              "p_value": { "type": "number" },
              "degrees_of_freedom": { "type": "number" },
              "effect_size": { "type": "number" }
            },
            "additionalProperties": false
          }
        },
        "not": {
          "anyOf": [
            { "required": ["model_diagnostics"] },
            { "required": ["assumption_tests"] }
          ]
        }
      }
    },

    {
      "if": { "properties": { "analysis_type": { "const": "correlation" } } },
      "then": {
        "properties": {
          "results": {
            "type": "object",
            "required": ["correlation_coefficient", "p_value"],
            "properties": {
              "correlation_coefficient": { "type": "number" },
              "p_value": { "type": "number" }
            },
            "additionalProperties": false
          }
        },
        "not": {
          "anyOf": [
            { "required": ["model_diagnostics"] },
            { "required": ["assumption_tests"] },
            { "required": ["confidence_level"] }
          ]
        }
      }
    }

  ]
}