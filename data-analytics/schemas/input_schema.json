{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Data Analytics Skill Input Schema",
  "description": "Strict input contract for Level 2 Statistical Engine.",
  "type": "object",
  "required": ["analysis_type", "dataset"],
  "properties": {

    "analysis_type": {
      "type": "string",
      "enum": [
        "eda",
        "linear_regression",
        "logistic_regression",
        "hypothesis_test",
        "correlation"
      ]
    },

    "dataset": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": {
          "type": ["number", "string", "boolean", "null"]
        }
      }
    },

    "target_variable": { "type": "string" },

    "independent_variables": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },

    "interaction_terms": {
      "type": "array",
      "items": {
        "type": "array",
        "minItems": 2,
        "maxItems": 2,
        "items": { "type": "string" }
      }
    },

    "test_type": {
      "type": "string",
      "enum": [
        "t_test_independent",
        "t_test_paired",
        "z_test_proportion",
        "chi_square",
        "anova_one_way"
      ]
    },

    "group_variable": { "type": "string" },

    "correlation_method": {
      "type": "string",
      "enum": ["pearson", "spearman"]
    },

    "confidence_level": {
      "type": "number",
      "minimum": 0.8,
      "maximum": 0.999
    }

  },

  "additionalProperties": false,

  "allOf": [

    {
      "if": {
        "properties": { "analysis_type": { "const": "linear_regression" } }
      },
      "then": {
        "required": ["target_variable", "independent_variables", "confidence_level"]
      }
    },

    {
      "if": {
        "properties": { "analysis_type": { "const": "logistic_regression" } }
      },
      "then": {
        "required": ["target_variable", "independent_variables", "confidence_level"]
      }
    },

    {
      "if": {
        "properties": { "analysis_type": { "const": "hypothesis_test" } }
      },
      "then": {
        "required": ["test_type", "group_variable", "confidence_level"]
      }
    },

    {
      "if": {
        "properties": { "analysis_type": { "const": "correlation" } }
      },
      "then": {
        "required": ["independent_variables", "correlation_method"]
      }
    },

    {
      "if": {
        "properties": {
          "analysis_type": {
            "enum": ["linear_regression", "logistic_regression"]
          }
        }
      },
      "then": {},
      "else": {
        "not": {
          "required": ["interaction_terms"]
        }
      }
    }

  ]
}